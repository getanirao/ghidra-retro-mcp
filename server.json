{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.getanirao/ghidra-retro-mcp",
  "version": "1.0.0",
  "description": "Headless Ghidra MCP server with P-code emulation and multi-console ROM triage.",
  "author": "getanirao",
  "license": "Apache-2.0",
  "repository": {
    "url": "https://github.com/getanirao/ghidra-retro-mcp",
    "type": "git",
    "source": "github"
  },
  "keywords": [
    "ghidra",
    "reverse-engineering",
    "mcp",
    "model-context-protocol",
    "retro-reversing",
    "p-code",
    "emulation",
    "firmware",
    "security-tools",
    "pyhidra",
    "rom-triage"
  ],
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "ghidra-retro-mcp",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "GHIDRA_INSTALL_DIR",
          "description": "Absolute path to the Ghidra installation directory",
          "isRequired": true,
          "isSecret": false,
          "format": "string"
        },
        {
          "name": "MOCK_MODE",
          "description": "Set to 1 for zero-dependency CI simulation",
          "isRequired": false,
          "isSecret": false,
          "format": "string",
          "default": "0"
        }
      ]
    }
  ]
}
